{
  "manifest_version": 3,
  "name": "NOL Noti",
  "version": "1.3",
  "description": "Monitor Interpark ticket queue and notify when it's your turn",
  "permissions": [
    "activeTab",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "https://tickets.interpark.com/*",
    "https://gpoticket.globalinterpark.com/*"
  ],
  "action": {
    "default_title": "NOL Noti",
    "default_icon": {
      "16": "icons/icon_NOL Noti_1.png",
      "48": "icons/icon_NOL Noti_1.png",
      "128": "icons/icon_NOL Noti_1.png"
    }
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://tickets.interpark.com/waiting*",
        "https://gpoticket.globalinterpark.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon_NOL Noti_1.png",
    "48": "icons/icon_NOL Noti_1.png",
    "128": "icons/icon_NOL Noti_1.png"
  }
}